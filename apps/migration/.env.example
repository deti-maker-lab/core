# PostgreSQL Configuration
POSTGRES_URI=postgresql://user:password@localhost:5432/makerlab
# Alternative: DATABASE_URL

# Snipe-IT Configuration
SNIPEIT_BASE_URL=http://snipeit
SNIPEIT_API_TOKEN=your-api-token-here
SNIPEIT_TIMEOUT_SECONDS=10

# Snipe-IT Category and Manufacturer Mappings (JSON format)
SNIPEIT_CATEGORY_MAP={"Memória": 1, "Placa Expansão": 2, "Consumiveis 3D": 3, "Microcomputador": 4}
SNIPEIT_MANUFACTURER_MAP={"Farnell": 1, "Esite": 2, "BeeVery Creative": 3}

# Fallback IDs
SNIPEIT_DEFAULT_CATEGORY_ID=1
SNIPEIT_DEFAULT_MANUFACTURER_ID=1

# Migration Settings
MIGRATION_BATCH_SIZE=100
SNIPEIT_API_DELAY_MS=100
